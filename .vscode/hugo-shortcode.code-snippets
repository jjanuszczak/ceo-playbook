  "highlight": {
    "prefix": ["HSC-highlight", "highlight"],
    "body": [
      "{{< highlight ${1:language}${2| , \"options\"|} >}}",
      "${TM_SELECTED_TEXT:${CLIPBOARD}}$0",
      "{{< /highlight >}}"
    ],
    "description": "Adds syntax highlighting to code. Documentation: https://gohugo.io/content-management/shortcodes/#highlight"
  },
  "instagram": {
    "prefix": ["HSC-instagram", "instagram"],
    "body": [
      "{{< instagram ${1:postid}${2| , hidecaption=true, hidecaption=false|} >}}"
    ],
    "description": "Embeds an Instagram post. Documentation: https://gohugo.io/content-management/shortcodes/#instagram"
  },
  "param": {
    "prefix": ["HSC-param", "param"],
    "body": [
      "{{< param ${1:name} >}}"
    ],
    "description": "Renders a parameter from the page's front matter, falling back to site configuration. Documentation: https://gohugo.io/content-management/shortcodes/#param"
  },
  "ref": {
    "prefix": ["HSC-ref", "ref"],
    "body": [
      "{{< ref \"${1:path}\" >}}"
    ],
    "description": "Returns an absolute URL to a page reference. Documentation: https://gohugo.io/content-management/shortcodes/#ref-and-relref"
  },
  "relref": {
    "prefix": ["HSC-relref", "relref"],
    "body": [
      "{{< relref \"${1:path}\" >}}"
    ],
    "description": "Returns a relative URL to a page reference. Documentation: https://gohugo.io/content-management/shortcodes/#ref-and-relref"
  },
