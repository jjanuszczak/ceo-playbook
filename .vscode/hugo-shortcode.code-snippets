{
  "details": {
    "prefix": ["HSC-details", "details"],
    "body": [
      "{{< details summary=\"${1:summary text}\" >}}",
      "$0",
      "{{< /details >}}"
    ],
    "description": "Inserts an HTML <details> element into the content. Documentation: https://gohugo.io/content-management/shortcodes/#details"
  },
